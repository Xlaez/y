{application,y_web,
             [{modules,['Elixir.YWeb','Elixir.YWeb.Application',
                        'Elixir.YWeb.AuthController','Elixir.YWeb.ConnCase',
                        'Elixir.YWeb.CoreComponents','Elixir.YWeb.Endpoint',
                        'Elixir.YWeb.ErrorHTML','Elixir.YWeb.ErrorJSON',
                        'Elixir.YWeb.FallbackController',
                        'Elixir.YWeb.FeedLive','Elixir.YWeb.Layouts',
                        'Elixir.YWeb.PageController','Elixir.YWeb.PageHTML',
                        'Elixir.YWeb.Plugs.LoadUser',
                        'Elixir.YWeb.Plugs.RateLimit',
                        'Elixir.YWeb.Plugs.RequireAuth',
                        'Elixir.YWeb.Plugs.SanitiseParams',
                        'Elixir.YWeb.Plugs.SecurityHeaders',
                        'Elixir.YWeb.PostLive','Elixir.YWeb.ProfileLive',
                        'Elixir.YWeb.Router','Elixir.YWeb.Telemetry']},
              {compile_env,[{y_web,[dev_routes],error}]},
              {optional_applications,[]},
              {applications,[kernel,stdlib,elixir,logger,runtime_tools,y_core,
                             y_repo,y_workers,phoenix,phoenix_live_view,
                             phoenix_ecto,redix,jason,bandit,mox,
                             telemetry_metrics,phoenix_live_dashboard,
                             telemetry_poller,plug_cowboy]},
              {description,"y_web"},
              {registered,[]},
              {vsn,"0.1.0"},
              {mod,{'Elixir.YWeb.Application',[]}}]}.
